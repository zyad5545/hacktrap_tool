import os
import re
import json
import joblib
import numpy as np
import requests
import urllib.parse
import hashlib
from datetime import datetime
from flask import Flask, request, jsonify
from flask_cors import CORS
from db import init_db, log_attack, update_attack_status, log_honeypot_event, update_honeypot_event
from blockchain import anchor_data
import logging
from functools import wraps

app = Flask(__name__)
CORS(app)

logging.basicConfig(level=logging.INFO)
logger = logging.getLogger(__name__)

# ===== CONFIG =====
MODEL_PATH = os.getenv("MODEL_PATH", "data/model.pkl")
XSS_MODEL_PATH = os.getenv("XSS_MODEL_PATH", "/app/xss_model.joblib")
DEFAULT_FEATURE_NAMES = [
    "cpu_percent",
    "memory_percent",
    "disk_usage",
    "network_connections",
    "process_count"
]

model = None
xss_model = None

# ===== INIT DB =====
init_db()

# ===== HELPER FUNCTIONS =====
def load_models():
    global model, xss_model
    try:
        model = joblib.load(MODEL_PATH)
        logger.info(f"System model loaded: {MODEL_PATH}")
    except Exception as e:
        logger.error(f"Failed to load system model: {e}")
        model = None

    try:
        xss_model = joblib.load(XSS_MODEL_PATH)
        logger.info(f"XSS model loaded: {XSS_MODEL_PATH}")
    except Exception as e:
        logger.warning(f"XSS model not found or failed to load: {e}")
        xss_model = None

def sanitize_string(input_string, max_length=1000):
    if not input_string:
        return ''
    truncated = input_string[:max_length]
    cleaned = re.sub(r'[<>"\'\\]', '', truncated)
    return cleaned

def count_special_chars(s):
    return sum(1 for c in s if not c.isalnum() and not c.isspace())

# ===== XSS DETECTION =====
def detect_xss(input_string):
    """
    Detect XSS using only AI model, no rule-based fallback.
    """
    if not input_string or not input_string.strip():
        return False, 0.0

    # Only use AI model detection
    if xss_model and "xss_vect" in xss_model and "xss_clf" in xss_model:
        vect = xss_model["xss_vect"]
        clf = xss_model["xss_clf"]
        try:
            X_vec = vect.transform([input_string])
            pred_prob = clf.predict_proba(X_vec)[0]
            score = float(pred_prob[1])
            # Use a threshold for detection
            return score > 0.7, score
        except Exception as e:
            logger.error(f"XSS AI prediction error: {e}")
            return False, 0.0
    
    # No fallback to heuristic if AI model is not available
    return False, 0.0
# ===== API KEY DECORATOR =====
def require_api_key(f):
    @wraps(f)
    def decorated(*args, **kwargs):
        api_key = request.headers.get('X-API-KEY')
        if api_key != "honeypot-secure-key":
            return jsonify({"error": "Invalid API key"}), 403
        return f(*args, **kwargs)
    return decorated

# ===== ENDPOINTS =====
@app.route("/health")
def health():
    return {"status": "ok"}

@app.route("/search", methods=["POST"])
def handle_search():
    data = request.get_json()
    query = data.get("query", "").strip()
    if not query:
        return jsonify({'query': '', 'results': ['يرجى إدخال استبحث صحيح']})

    logger.info(f"📨 Search query: '{query}' from {request.remote_addr}")
    is_xss, score = detect_xss(query)

    if is_xss:
        safe_query = sanitize_string(query)
        
        # Log the XSS attack to database
        attack_id = log_attack(
            attack_type="xss",
            source_ip=request.remote_addr,
            severity="high",
            details=json.dumps({
                "query": safe_query,
                "score": score,
                "user_agent": request.headers.get("User-Agent", "")
            }),
            target_resource="/search",
            anomaly_score=score
        )
        
        # Anchor to blockchain
        attack_data = {
            "attack_type": "xss",
            "source_ip": request.remote_addr,
            "query": safe_query,
            "timestamp": datetime.now().isoformat(),
            "score": score
        }
        
        tx_hash = anchor_data(attack_data)
        if tx_hash:
            update_attack_status(attack_id, "anchored", tx_hash)
        
        honeypot_url = f"/fake_search.html?q={urllib.parse.quote(safe_query)}"
        return jsonify({
            'redirect': honeypot_url,
            'message': 'Search processed'
        })

    return jsonify({'query': query, 'results': ['نتيجة بحث عادية 1', 'نتيجة بحث عادية 2']})

# endpoint جديد أو استبدال القديم
@app.route("/api/honeypot/capture", methods=["POST"])
def capture_honeypot_data():
    try:
        data = request.get_json(force=True)
    except Exception:
        return jsonify({"error": "Invalid JSON"}), 400

    # اجمع بيانات آمنة
    sanitized = {
        "source_ip": request.remote_addr,
        "user_agent": (data.get("userAgent") or request.headers.get("User-Agent") or "")[:1024],
        "cookies": (data.get("cookies") or "")[:2048],
        "payload": (data.get("payload") or data.get("query") or "")[:4096],
        "headers": dict(request.headers),
        "timestamp": datetime.now().isoformat()
    }

    try:
        event_id = log_honeypot_event(sanitized)
        
        # Anchor to blockchain
        blockchain_data = {
            "event_type": "honeypot_capture",
            "source_ip": sanitized["source_ip"],
            "timestamp": sanitized["timestamp"],
            "payload_hash": hashlib.sha256(sanitized["payload"].encode()).hexdigest()
        }
        
        tx_hash = anchor_data(blockchain_data)
        
        if tx_hash:
            update_honeypot_event(event_id, {"anchored_tx": tx_hash})

        return jsonify({
            "status": "success",
            "event_id": event_id,
            "anchored_tx": tx_hash
        }), 201

    except Exception as e:
        logger.error(f"DB insert failed: {e}")
        return jsonify({"error": "DB insert failed"}), 500

# ===== TEST & DEBUG =====
@app.route("/test/xss", methods=["POST"])
def test_xss_detection():
    query = request.get_json().get("query", "")
    is_xss, score = detect_xss(query)
    return jsonify({"query": query, "is_xss": is_xss, "score": score})

@app.route("/test", methods=["GET"])
def test_endpoint():
    return jsonify({"status": "success", "message": "الخادم يعمل بشكل صحيح"})

@app.route("/login", methods=["POST"])
def login():
    data = request.get_json()
    username = data.get("username", "")
    password = data.get("password", "")

    # Check AI / heuristic rules
    is_suspicious = False
    if len(username) > 5 or len(password) > 5:  # simple heuristic
        is_suspicious = True

    if is_suspicious:
        # Log to honeypot
        log_honeypot_event({
            "timestamp": datetime.now().isoformat(),
            "source_ip": request.remote_addr,
            "user_agent": request.headers.get("User-Agent"),
            "form": "login",
            "json_payload": json.dumps(data),
            "headers": json.dumps(dict(request.headers)),
            "raw": str(request.data)
        })
        return jsonify({"status": "suspicious", "message": "Activity detected by AI"}), 200

    return jsonify({"status": "ok", "message": "Login attempt received"})

# ===== MAIN =====
if __name__ == "__main__":
    load_models()
    app.run(host="0.0.0.0", port=8000)
