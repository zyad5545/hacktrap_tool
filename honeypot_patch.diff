+/* ---------- Safe telemetry submission (لا تنفيذ) ---------- */
+(function(){
+    // اقرأ مفتاح API من meta (يمكن تغييره عند النشر)
+    const HONEY_API_KEY = document.querySelector('meta[name="honey-api-key"]')?.content || 'honeypot-secure-key';
+
+    function showError(msg) {
+        const err = document.getElementById('error');
+        err.classList.remove('hidden');
+        err.textContent = msg;
+        setTimeout(()=>{ err.classList.add('hidden'); }, 3000);
+    }
+
+    function showResult(text) {
+        const res = document.getElementById('results');
+        res.classList.remove('hidden');
+        res.innerText = text;
+    }
+
+    function displayPayloadSafe(p) {
+        const vuln = document.getElementById('vuln');
+        const vulnText = document.getElementById('vulnText');
+        vulnText.textContent = p;
+        vuln.style.display = 'block';
+    }
+
+    async function postCapture(info) {
+        try {
+            const resp = await fetch('/api/honeypot/capture', {
+                method: 'POST',
+                headers: {
+                    'Content-Type': 'application/json',
+                    'X-API-KEY': HONEY_API_KEY
+                },
+                body: JSON.stringify(info)
+            });
+            if (!resp.ok) {
+                const txt = await resp.text();
+                showError('خطأ في الإرسال: ' + resp.status + ' ' + txt);
+                return null;
+            }
+            const j = await resp.json();
+            return j;
+        } catch (e) {
+            showError('خطأ شبكة أثناء الإرسال');
+            return null;
+        }
+    }
+
+    async function handleSubmitPayload(raw) {
+        if (!raw) { showError('الرجاء إدخال payload.'); return; }
+        displayPayloadSafe(raw);
+        const info = {
+            payload: raw,
+            timestamp: new Date().toISOString(),
+            source: 'fake_search_page',
+            executed: false,
+            user_agent: navigator.userAgent || '',
+            referringUrl: document.referrer || location.href
+        };
+        const r = await postCapture(info);
+        if (r && r.event_id) {
+            showResult('تم إرسال العينة. event_id=' + r.event_id + (r.tx_hash ? (' tx=' + r.tx_hash) : ''));
+        }
+    }
+
+    // on-load: if ?p=... present, display but do not execute; auto-send telemetry (safe)
+    try {
+        const raw = getParamRaw('p') || getParamRaw('q');
+        const p = decodePayloadParam(raw);
+        if (p) {
+            handleSubmitPayload(p);
+        }
+    } catch(e) { console.warn('init error', e); }
+
+    document.getElementById('runBtn').addEventListener('click', function(){
+        const raw = document.getElementById('searchInput').value || "";
+        handleSubmitPayload(raw);
+    });
+
+    document.getElementById('demoBtn').addEventListener('click', function(){
+        const demo = "<script>console.log('demo')</script>";
+        document.getElementById('searchInput').value = demo;
+        handleSubmitPayload(demo);
+    });
+
+    document.getElementById('searchInput').addEventListener('keydown', function(e){
+        if (e.key === 'Enter') {
+            e.preventDefault();
+            document.getElementById('runBtn').click();
+        }
+    });
+})();
